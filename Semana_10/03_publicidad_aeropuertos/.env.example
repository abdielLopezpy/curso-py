# ============================================================================
# VARIABLES DE ENTORNO - PUBLICIDAD EN AEROPUERTOS
# ============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo y renombralo a .env
# 2. Reemplaza los valores con tus propias credenciales
# 3. NUNCA subas el archivo .env a Git (ya esta en .gitignore)
# ============================================================================

# --- Base de Datos (Neon PostgreSQL) ---
# Obten tu URL en: https://neon.tech
DATABASE_URL=postgresql://usuario:contraseña@host/basededatos?sslmode=require

# --- Flask ---
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura

# --- Stripe (Pasarela de Pagos) ---
# Obten tus claves en: https://dashboard.stripe.com/apikeys
# Usa las claves de PRUEBA (test) para desarrollo:
#   - Empiezan con pk_test_ y sk_test_
# Usa las claves LIVE para produccion:
#   - Empiezan con pk_live_ y sk_live_
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
